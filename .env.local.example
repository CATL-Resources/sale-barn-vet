# Sale Barn Vet — local environment.
#
# Copy this file to `.env.local` (which is gitignored) and paste the values from the
# Supabase dashboard for the "Sale Barn Vet" project (ref: odrcpdnzhnyiofokokum):
#   Project Settings -> API -> Project URL  -> NEXT_PUBLIC_SUPABASE_URL
#   Project Settings -> API -> anon / public key -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Never commit real keys. .env.local is ignored by git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — only for `npm run test:db` to verify RLS as a logged-in user.
# Leave blank to test the logged-out path (expects 0 rows). Fill in after the first
# admin/member account is bootstrapped to see the seeded rows.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
